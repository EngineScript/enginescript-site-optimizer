msgstr ""

#: enginescript-site-optimizer.php:433
msgid "DNS Prefetch Domains"
msgstr ""

#: enginescript-site-optimizer.php:434
msgid "DNS-prefetch is a lighter-weight alternative to preconnect that performs only the DNS lookup. Use it for less critical domains or as a fallback for browsers that don't support preconnect. Enter one HTTPS domain per line (e.g., https://adservice.google.com). Only clean domains are allowed - no file paths, query parameters, or fragments."
msgstr ""

